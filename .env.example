# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================================================
# LLM API Configuration
# ============================================================================
# Choose your LLM provider and configure accordingly:

# Example 1: SiliconFlow (硅基流动)
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=your_siliconflow_api_key_here
# LLM_MODEL=zai-org/GLM-4.6V

# Example 2: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4

# Example 3: Zhipu AI (智谱)
# LLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
# LLM_API_KEY=your_zhipu_api_key_here
# LLM_MODEL=claude-3-5-sonnet-20241022

# Uncomment and fill in the values you want to use:
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=

# ============================================================================
# Email Configuration
# ============================================================================

# Email sending method: "resend" or "smtp"
EMAIL_METHOD=smtp

# -----
# Option 1: Resend (需要国外服务)
# -----
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev

# -----
# Option 2: SMTP (163, QQ, etc.)
# -----

# Example 1: 163 Mail (网易)
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_USER=your_email@163.com
# SMTP_PASSWORD=your_authorization_code
# SMTP_FROM_EMAIL=your_email@163.com

# Example 2: QQ Mail (腾讯)
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your_email@qq.com
# SMTP_PASSWORD=your_authorization_code
# SMTP_FROM_EMAIL=your_email@qq.com

# Example 3: Gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=your_email@gmail.com

# Recipient email (收件人邮箱，支持多个，用逗号分隔)
# Single recipient:
# EMAIL_TO=user1@example.com
# Multiple recipients:
# EMAIL_TO=user1@example.com,user2@example.com,user3@example.com
EMAIL_TO=your-email@example.com

# ============================================================================
# Database Configuration
# ============================================================================
DB_PATH=data/trends.db
DB_RETENTION_DAYS=30

# Alert threshold (installation surge detection, 0.3 = 30%)
SURGE_THRESHOLD=0.3
